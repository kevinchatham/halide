{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "es2022",
    "target": "es2022",
    "moduleResolution": "bundler",
    "types": ["node"],
    "typeRoots": ["../../node_modules/@types"],
    "paths": {
      "bspa": ["../../src"],
      "bspa/*": ["../../src/*"]
    },
    "baseUrl": "."
  },
  "include": ["server.ts"]
}