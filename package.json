{
  "name": "halide",
  "version": "0.0.7",
  "description": "A declarative BFF (Backend for Frontend) runtime that standardizes SPA communication with auth, proxy, CSP, rate limiting, and OpenAPI support",
  "keywords": [
    "angular",
    "api",
    "authentication",
    "backend-for-frontend",
    "bff",
    "cli",
    "cors",
    "csp",
    "esm",
    "hono",
    "jwks",
    "jwt",
    "openapi",
    "proxy",
    "rate-limit",
    "react",
    "server",
    "spa",
    "svelte",
    "typescript",
    "vue"
  ],
  "license": "MIT",
  "author": "kevinchatham",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinchatham/halide.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./*": "./dist/*"
  },
  "bin": {
    "halide": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prebuild": "npx tsx scripts/update-readme.ts && npm run typecheck",
    "build": "tsup",
    "cli": "node dist/cli/index.js",
    "clean": "npx tsx scripts/clean.ts",
    "demo:angular:build": "cd demo/angular && npm run build",
    "demo:angular:install": "cd demo/angular && npm install",
    "demo:angular:serve": "cd demo/angular && npm run serve",
    "demo:angular:serve:server": "cd demo/angular && npm run serve:server",
    "demo:backend:build": "cd demo/backend && npm run build",
    "demo:backend:install": "cd demo/backend && npm install",
    "demo:backend:serve": "cd demo/backend && npm run serve",
    "demo:install": "npm run demo:link && npm run demo:angular:install && npm run demo:backend:install",
    "demo:link": "npm run build && npm link && cd demo/angular && npm link halide",
    "kill": "fuser -k 3000/tcp && fuser -k 3553/tcp && fuser -k 4200/tcp",
    "lint": "biome check --config-path biome.json .",
    "lint:fix": "biome check --config-path biome.json  --write . && prettier --write . --config .prettierrc --ignore-path .prettierignore",
    "lint:watch": "nodemon --exec 'npm run lint:fix' --watch '**/*.ts' --watch '**/*.json' --ext '.ts,.json'",
    "sonar": "npm run test && npx dotenv -- npx sonar",
    "test": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.10.9",
    "hono": "^4.12.14",
    "hono-openapi": "^1.3.0",
    "strip-json-comments": "^5.0.1",
    "zod": "^3.23.0",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@sonar/scan": "^4.3.5",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.15",
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.4"
  }
}
