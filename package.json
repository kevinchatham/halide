{
  "name": "bspa",
  "version": "1.0.0",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js",
    "./*": "./dist/src/*"
  },
  "scripts": {
    "build": "tsc",
    "clean": "npx tsx scripts/clean.ts",
    "demo:angular:build": "cd demo/angular-spa && npm run build",
    "demo:angular:install": "cd demo/angular-spa && npm install",
    "demo:angular:serve:server": "cd demo/angular-spa && npm run serve:server",
    "demo:angular:serve": "cd demo/angular-spa && npm run serve",
    "demo:backend:build": "cd demo/backend && npm run build",
    "demo:backend:install": "cd demo/backend && npm install",
    "demo:backend:serve": "cd demo/backend && npm run serve",
    "demo:install": "npm run build && npm run demo:angular:install && npm run demo:backend:install",
    "lint:fix": "biome check --write .",
    "lint:watch": "nodemon --exec 'biome check --fix .' --watch '**/*.ts' --watch '**/*.json' --ext '.ts,.json'",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.0",
    "jose": "^5.9.0",
    "nodemon": "^3.1.14",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@angular/cli": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@biomejs/biome": "^1.9.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.0"
  }
}
