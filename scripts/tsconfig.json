{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "Node16",
    "moduleDetection": "force",
    "moduleResolution": "node16",
    "noUncheckedIndexedAccess": true,
    "outDir": "./dist",
    "rootDirs": ["./src", "./scripts"],
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "typeRoots": ["../node_modules/@types"],
    "types": ["node"]
  },
  "include": ["clean.ts"]
}
